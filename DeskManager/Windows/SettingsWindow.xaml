<Window x:Class="DeskManager.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DeskManager – Einstellungen"
        Width="740"
        Height="580"
        WindowStartupLocation="CenterScreen"
        Background="#FF0F0F1F"
        Foreground="White"
        ResizeMode="CanResize"
        MinWidth="680"
        MinHeight="500"
        ShowInTaskbar="True">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#440F3460"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#55FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#660F3460"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#990F3460"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#22FFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="BorderBrush" Value="#44FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style x:Key="ContentListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="#22FFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#44FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="ContentListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="8,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#440F3460"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="#880F3460"/>
        </Style>

        <!-- Sidebar ListBox -->
        <Style x:Key="SidebarStyle" TargetType="ListBox">
            <Setter Property="Background" Value="#0A0A18"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Hidden"/>
        </Style>

        <!-- Sidebar ListBoxItem -->
        <Style x:Key="SidebarItemStyle" TargetType="ListBoxItem">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Grid Height="40">
                            <Rectangle x:Name="Indicator"
                                       Width="3"
                                       HorizontalAlignment="Left"
                                       Fill="#22FF7F"
                                       Visibility="Collapsed"/>
                            <Border x:Name="Bg"
                                    Background="Transparent"
                                    Margin="3,0,0,0">
                                <ContentPresenter VerticalAlignment="Center" Margin="12,0"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#1A1A3A"/>
                                <Setter TargetName="Indicator" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#15152A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ SIDEBAR ═══ -->
        <Grid Grid.Column="0" Background="#0A0A18">
            <ListBox x:Name="SidebarNav"
                     Style="{StaticResource SidebarStyle}"
                     ItemContainerStyle="{StaticResource SidebarItemStyle}"
                     SelectionChanged="SidebarNav_SelectionChanged"
                     SelectedIndex="0"
                     Margin="0,8,0,0">
                <ListBoxItem>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="White" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Welcome" FontSize="12" Foreground="#E0E0E0" VerticalAlignment="Center"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE790;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="White" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Personalization" FontSize="12" Foreground="#E0E0E0" VerticalAlignment="Center"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xED1A;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="White" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Hide" FontSize="12" Foreground="#E0E0E0" VerticalAlignment="Center"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8D4;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="White" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Spaces" FontSize="12" Foreground="#E0E0E0" VerticalAlignment="Center"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="White" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="General" FontSize="12" Foreground="#E0E0E0" VerticalAlignment="Center"/>
                    </StackPanel>
                </ListBoxItem>
                <!-- Non-selectable separator -->
                <ListBoxItem IsEnabled="False" IsHitTestVisible="False" Padding="0" Height="17">
                    <Separator Background="#44FFFFFF" Margin="12,0"/>
                </ListBoxItem>
                <ListBoxItem>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE82D;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="White" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Wiki" FontSize="12" Foreground="#E0E0E0" VerticalAlignment="Center"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="White" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="About" FontSize="12" Foreground="#E0E0E0" VerticalAlignment="Center"/>
                    </StackPanel>
                </ListBoxItem>
            </ListBox>
        </Grid>

        <!-- ═══ CONTENT AREA ═══ -->
        <Grid Grid.Column="1" Background="#0F0F1F">
            <!-- Divider -->
            <Border Width="1" HorizontalAlignment="Left" Background="#22FFFFFF"/>

            <!-- ── Welcome ── -->
            <Grid x:Name="PageWelcome" Visibility="Visible">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
                    <StackPanel Margin="28,24,28,24">
                        <TextBlock Text="Welcome"
                                   FontSize="20" FontWeight="Bold" Foreground="White"
                                   Margin="0,0,0,20"/>
                        <TextBlock Text="DeskManager"
                                   FontSize="28" FontWeight="Bold" Foreground="#22FF7F"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="Dein Desktop. Organisiert."
                                   FontSize="13" Foreground="#AAAAAA"
                                   Margin="0,0,0,28"/>
                        <Border Background="#220F3460" BorderBrush="#44FFFFFF" BorderThickness="1"
                                CornerRadius="6" Padding="16,14" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="⚡ Quick Start"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="#FFB3E5FC" Margin="0,0,0,8"/>
                                <TextBlock Text="Halte Ctrl und ziehe auf dem Desktop um ein Grid zu erstellen."
                                           FontSize="11" Foreground="#CCCCCC" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ── Personalization ── -->
            <Grid x:Name="PagePersonalization" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
                    <StackPanel Margin="28,24,28,24">
                        <TextBlock Text="Personalization"
                                   FontSize="20" FontWeight="Bold" Foreground="White"
                                   Margin="0,0,0,20"/>
                        <TextBlock Text="Grid-Farben anpassen"
                                   FontSize="14" FontWeight="Bold" Foreground="#FFFFFF"
                                   Margin="0,0,0,14"/>

                        <!-- Background -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Hintergrund" Foreground="#E0E0E0" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Text="Hauptfarbe der Grids" Foreground="#888888" FontSize="10" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" x:Name="BgColorBtn" Width="36" Height="28"
                                    Click="BgColorBtn_Click" ToolTip="Farbe wählen" Padding="0" Margin="0,0,8,0"/>
                            <Slider Grid.Column="2" x:Name="BgOpacity" Minimum="0" Maximum="255"
                                    VerticalAlignment="Center" Margin="0,0,8,0" ValueChanged="BgOpacity_Changed"/>
                            <TextBlock Grid.Column="3" x:Name="BgOpacityLabel" VerticalAlignment="Center"
                                       Foreground="#88FFFFFF" FontSize="10" TextAlignment="Right"/>
                        </Grid>

                        <!-- Title Bar -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Titelleiste" Foreground="#E0E0E0" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Text="Balken oben im Grid" Foreground="#888888" FontSize="10" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" x:Name="TitleColorBtn" Width="36" Height="28"
                                    Click="TitleColorBtn_Click" Padding="0" Margin="0,0,8,0"/>
                            <Slider Grid.Column="2" x:Name="TitleOpacity" Minimum="0" Maximum="255"
                                    VerticalAlignment="Center" ValueChanged="TitleOpacity_Changed" Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="3" x:Name="TitleOpacityLabel" VerticalAlignment="Center"
                                       Foreground="#88FFFFFF" FontSize="10" TextAlignment="Right"/>
                        </Grid>

                        <!-- Border -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Rahmen" Foreground="#E0E0E0" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Text="Kanten des Grids" Foreground="#888888" FontSize="10" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" x:Name="BorderColorBtn" Width="36" Height="28"
                                    Click="BorderColorBtn_Click" Padding="0" Margin="0,0,8,0"/>
                            <Slider Grid.Column="2" x:Name="BorderOpacity" Minimum="0" Maximum="255"
                                    VerticalAlignment="Center" ValueChanged="BorderOpacity_Changed" Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="3" x:Name="BorderOpacityLabel" VerticalAlignment="Center"
                                       Foreground="#88FFFFFF" FontSize="10" TextAlignment="Right"/>
                        </Grid>

                        <!-- Text -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Textfarbe" Foreground="#E0E0E0" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Text="Icon-Beschriftung" Foreground="#888888" FontSize="10" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" x:Name="TextColorBtn" Width="36" Height="28"
                                    Click="TextColorBtn_Click" Padding="0" Margin="0,0,8,0"/>
                            <Slider Grid.Column="2" x:Name="TextOpacity" Minimum="0" Maximum="255"
                                    VerticalAlignment="Center" ValueChanged="TextOpacity_Changed" Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="3" x:Name="TextOpacityLabel" VerticalAlignment="Center"
                                       Foreground="#88FFFFFF" FontSize="10" TextAlignment="Right"/>
                        </Grid>

                        <!-- Preview -->
                        <TextBlock Text="Vorschau" FontSize="12" FontWeight="Bold"
                                   Foreground="#FFFFFF" Margin="0,0,0,10"/>
                        <Border x:Name="PreviewBorder" CornerRadius="8" BorderThickness="1"
                                Width="240" HorizontalAlignment="Left" Height="110">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="32"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border x:Name="PreviewTitle" Grid.Row="0" CornerRadius="8,8,0,0">
                                    <TextBlock x:Name="PreviewTitleText" Text="Mein Grid"
                                               FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="10,0"/>
                                </Border>
                                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="📁 Dokumente" Foreground="#66FFFFFF" FontSize="9"
                                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <TextBlock Text="📊 Bilder" Foreground="#66FFFFFF" FontSize="9"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ── Hide ── -->
            <Grid x:Name="PageHide" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
                    <StackPanel Margin="28,24,28,24">
                        <TextBlock Text="Hide"
                                   FontSize="20" FontWeight="Bold" Foreground="White"
                                   Margin="0,0,0,20"/>

                        <Border Background="#220F3460" BorderBrush="#44FFFFFF" BorderThickness="1"
                                CornerRadius="6" Padding="14,12" Margin="0,0,0,16">
                            <StackPanel>
                                <CheckBox x:Name="NotificationsCheckbox"
                                          Content="🔔 Benachrichtigungen aktivieren"
                                          Foreground="#FFB3E5FC" FontSize="11"
                                          Checked="Notifications_Changed"
                                          Unchecked="Notifications_Changed"
                                          Margin="0,0,0,6"/>
                                <TextBlock Text="Zeige Benachrichtigungen wenn Grids oder Desktop Icons ausgeblendet werden"
                                           Foreground="#888888" FontSize="10"
                                           TextWrapping="Wrap" Margin="20,0,0,0"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Tastenkürzel"
                                   FontSize="13" FontWeight="Bold" Foreground="White"
                                   Margin="0,8,0,12"/>

                        <Border Background="#220F3460" BorderBrush="#44FFFFFF" BorderThickness="1"
                                CornerRadius="6" Padding="14,12" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Alles ein-/ausblenden"
                                           Foreground="#FFB3E5FC" FontSize="11" FontWeight="SemiBold"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Ctrl + Doppelklick (LINKE Maustaste) auf dem Desktop"
                                           Foreground="#AAAAAA" FontSize="10" TextWrapping="Wrap"/>
                                <TextBlock Text="Blendet alle Grids UND Desktop-Dateien ein oder aus."
                                           Foreground="#666666" FontSize="10" TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#220F3460" BorderBrush="#44FFFFFF" BorderThickness="1"
                                CornerRadius="6" Padding="14,12">
                            <StackPanel>
                                <TextBlock Text="Nur Desktop-Dateien verstecken"
                                           Foreground="#FFB3E5FC" FontSize="11" FontWeight="SemiBold"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Ctrl + Doppelklick (RECHTE Maustaste) auf dem Desktop"
                                           Foreground="#AAAAAA" FontSize="10" TextWrapping="Wrap"/>
                                <TextBlock Text="Versteckt nur die Desktop-Dateien. Grids bleiben sichtbar!"
                                           Foreground="#666666" FontSize="10" TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ── Spaces ── -->
            <Grid x:Name="PageSpaces" Visibility="Collapsed" Margin="28,24,28,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Spaces"
                           FontSize="20" FontWeight="Bold" Foreground="White"
                           Margin="0,0,0,16"/>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock Text="Deine Spaces" FontSize="13" FontWeight="Bold"
                                       Foreground="#FFFFFF" Margin="0,0,0,4"/>
                            <TextBlock Text="Erstelle mehrere Desktops für verschiedene Aufgaben"
                                       FontSize="10" Foreground="#888888"/>
                        </StackPanel>
                        <ListBox Grid.Row="1"
                                 x:Name="SpacesList"
                                 Style="{StaticResource ContentListBoxStyle}"
                                 ItemContainerStyle="{StaticResource ContentListBoxItemStyle}"
                                 SelectionChanged="SpacesList_SelectionChanged"
                                 MinHeight="120"
                                 Margin="0,0,12,0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="ActiveDot" Text="● "
                                                   Foreground="#22FF7F" FontSize="10"
                                                   VerticalAlignment="Center"
                                                   Visibility="Collapsed" Margin="0,0,4,0"/>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                    <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="0,32,0,0">
                        <Button Content="➕ Neu" Click="AddSpace_Click" Margin="0,0,0,8"/>
                        <Button Content="✏️ Umbenennen" x:Name="RenameSpaceBtn"
                                Click="RenameSpace_Click" Margin="0,0,0,8" IsEnabled="False"/>
                        <Button Content="🔄 Wechseln" x:Name="SwitchSpaceBtn"
                                Click="SwitchSpace_Click" Margin="0,0,0,12" IsEnabled="False"/>
                        <Button Content="🗑️ Löschen" x:Name="DeleteSpaceBtn"
                                Click="DeleteSpace_Click" Foreground="#FFCF6679"
                                Background="#663366" IsEnabled="False"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- ── General ── -->
            <Grid x:Name="PageGeneral" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
                    <StackPanel Margin="28,24,28,24">
                        <TextBlock Text="General"
                                   FontSize="20" FontWeight="Bold" Foreground="White"
                                   Margin="0,0,0,20"/>

                        <Border Background="#220F3460" BorderBrush="#44FFFFFF" BorderThickness="1"
                                CornerRadius="6" Padding="14,12" Margin="0,0,0,16">
                            <StackPanel>
                                <CheckBox x:Name="AutostartCheckbox"
                                          Content="🚀 Bei Windows-Start ausführen"
                                          Foreground="#FFB3E5FC" FontSize="11"
                                          Checked="Autostart_Changed"
                                          Unchecked="Autostart_Changed"
                                          Margin="0,0,0,6"/>
                                <TextBlock Text="DeskManager wird automatisch gestartet, wenn du deinen Computer hochfährst"
                                           Foreground="#888888" FontSize="10"
                                           TextWrapping="Wrap" Margin="20,0,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#220F3460" BorderBrush="#44FFFFFF" BorderThickness="1"
                                CornerRadius="6" Padding="14,12" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="⬆️ Updates prüfen"
                                           Foreground="#FFB3E5FC" FontSize="11" FontWeight="Bold"
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="Prüfe manuell auf verfügbare Updates"
                                           Foreground="#888888" FontSize="10"
                                           TextWrapping="Wrap" Margin="0,0,0,10"/>
                                <Button Content="Auf Updates prüfen"
                                        Click="CheckForUpdates_Click"
                                        Padding="12,6" FontSize="10"
                                        Width="Auto" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ── Wiki ── -->
            <Grid x:Name="PageWiki" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
                    <StackPanel Margin="28,24,28,24">
                        <TextBlock Text="Wiki"
                                   FontSize="20" FontWeight="Bold" Foreground="White"
                                   Margin="0,0,0,20"/>
                        <TextBlock Text="Wie benutze ich DeskManager?"
                                   FontSize="13" FontWeight="Bold" Foreground="#FFFFFF"
                                   Margin="0,0,0,14"/>

                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="🖱️ Grids erstellen" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#FFB3E5FC" Margin="0,0,0,4"/>
                            <TextBlock Text="Halte Ctrl gedrückt, klicke auf den Desktop und verschiebe die Maus um ein Grid zu zeichnen. Ein Menü zeigt 'Grid hier erstellen'."
                                       FontSize="10" Foreground="#AAAAAA" TextWrapping="Wrap"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="📁 Dateien hinzufügen" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#FFB3E5FC" Margin="0,0,0,4"/>
                            <TextBlock Text="Ziehe Dateien oder Ordner per Drag &amp; Drop auf ein Grid. Die Dateien werden sicher gespeichert und vom Desktop entfernt."
                                       FontSize="10" Foreground="#AAAAAA" TextWrapping="Wrap"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="🔄 Alles Ein-/Ausblenden" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#FFB3E5FC" Margin="0,0,0,4"/>
                            <TextBlock Text="Doppelklick: Halte Ctrl und klicke zweimal mit der LINKEN Maustaste auf den Desktop um alle Grids UND Desktop-Dateien ein-/auszublenden."
                                       FontSize="10" Foreground="#AAAAAA" TextWrapping="Wrap"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="🖥️ Nur Desktop-Dateien verstecken" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#FFB3E5FC" Margin="0,0,0,4"/>
                            <TextBlock Text="Doppelklick: Halte Ctrl und klicke zweimal mit der RECHTEN Maustaste auf den Desktop um nur die Desktop-Dateien ein-/auszublenden. Grids bleiben sichtbar!"
                                       FontSize="10" Foreground="#AAAAAA" TextWrapping="Wrap"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="🗂️ Tabs und Gruppen" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#FFB3E5FC" Margin="0,0,0,4"/>
                            <TextBlock Text="Halte Ctrl gedrückt und ziehe ein Grid auf ein anderes, um Tabs zu erstellen. Klicke auf die Tabs um zwischen verschiedenen Items zu wechseln."
                                       FontSize="10" Foreground="#AAAAAA" TextWrapping="Wrap"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="🎨 Design ändern" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#FFB3E5FC" Margin="0,0,0,4"/>
                            <TextBlock Text="Gehe zu 'Personalization' um Farben und Transparency anzupassen. Die Vorschau zeigt deine Änderungen in Echtzeit."
                                       FontSize="10" Foreground="#AAAAAA" TextWrapping="Wrap"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="🗑️ Items entfernen" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#FFB3E5FC" Margin="0,0,0,4"/>
                            <TextBlock Text="Rechtklick auf ein Item im Grid und wähle 'Aus Grid entfernen'. Die Datei erscheint wieder auf deinem Desktop."
                                       FontSize="10" Foreground="#AAAAAA" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ── About ── -->
            <Grid x:Name="PageAbout" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
                    <StackPanel Margin="28,24,28,24">
                        <TextBlock Text="About"
                                   FontSize="20" FontWeight="Bold" Foreground="White"
                                   Margin="0,0,0,20"/>

                        <Border Background="#220F3460" BorderBrush="#77FF6B6B" BorderThickness="1"
                                CornerRadius="6" Padding="14,12" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="⚠️ Reset alle Einstellungen"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="#FFFF8C8C" Margin="0,0,0,8"/>
                                <TextBlock Text="Das setzt alle Fenster auf Standardpositionen zurück und stellt die Farben zurück. Alle Dateien in deinen Grids werden wieder auf deinen Desktop angezeigt."
                                           FontSize="10" Foreground="#AAAAAA"
                                           TextWrapping="Wrap" Margin="0,0,0,10"/>
                                <Button Content="🔄 Alles Zurücksetzen"
                                        Click="ResetAll_Click"
                                        Foreground="#FFFF8C8C"
                                        Background="#665533"
                                        Padding="10,8"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#220F3460" BorderBrush="#4488DDFF" BorderThickness="1"
                                CornerRadius="6" Padding="14,12">
                            <StackPanel>
                                <TextBlock Text="ℹ️ Informationen"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="#FFB3E5FC" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Version:" Foreground="#888888" FontSize="10"/>
                                    <TextBlock Grid.Column="1" x:Name="VersionLabel"
                                               Text="1.0.0" Foreground="#AAAAAA" FontSize="10"/>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Speicher:" Foreground="#888888" FontSize="10"/>
                                    <TextBlock Grid.Column="1" x:Name="StorageLabel"
                                               Text="%APPDATA%/DeskManager" Foreground="#AAAAAA"
                                               FontSize="10" TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

        </Grid>
    </Grid>
</Window>
