<Window x:Class="DeskManager.Windows.GridWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        MinWidth="130"
        MinHeight="38"
        Title="DeskManager"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">

    <Window.Resources>
        <Style x:Key="HeaderBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#CCFFFFFF"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#55FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Scrollbar style - thin & subtle -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#55FFFFFF" CornerRadius="3"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Drop shadow effect via outer border -->
    <Border Margin="4">
        <Border.Effect>
            <DropShadowEffect BlurRadius="8" Opacity="0.5" ShadowDepth="2" Color="#000000"/>
        </Border.Effect>

        <Border x:Name="MainBorder"
                CornerRadius="8"
                Background="{DynamicResource GridBackgroundBrush}"
                BorderBrush="{DynamicResource GridBorderBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="TitleRow" Height="30"/>
                    <RowDefinition x:Name="ContentRow" Height="*"/>
                    <RowDefinition x:Name="ResizeRow" Height="8"/>
                </Grid.RowDefinitions>

                <!-- ═══ TITLE BAR ═══ -->
                <Border x:Name="TitleBarBorder"
                        Grid.Row="0"
                        Background="{DynamicResource TitleBarBrush}"
                        CornerRadius="8,8,0,0"
                        Cursor="SizeAll"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                        MouseRightButtonDown="TitleBar_MouseRightButtonDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="26"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                        </Grid.ColumnDefinitions>

                        <!-- Collapse toggle -->
                        <Button Grid.Column="0"
                                x:Name="CollapseBtn"
                                Style="{StaticResource HeaderBtn}"
                                Click="CollapseBtn_Click"
                                Margin="3,0,0,0">
                            <TextBlock x:Name="CollapseIcon" Text="▾" FontSize="11"/>
                        </Button>

                        <!-- Title or Tabs (Column 1) -->
                        <Grid Grid.Column="1">
                            <!-- Title label (when no tabs) -->
                            <TextBlock x:Name="TitleLabel"
                                       Foreground="{DynamicResource GridTextBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Left"
                                       Margin="4,0"
                                       MaxWidth="160"
                                       Cursor="IBeam"
                                       TextTrimming="CharacterEllipsis"/>

                            <!-- Title edit (edit mode) -->
                            <TextBox x:Name="TitleBox"
                                     Visibility="Collapsed"
                                     FontSize="12"
                                     VerticalAlignment="Center"
                                     Margin="4,2"
                                     Background="#33000000"
                                     Foreground="White"
                                     CaretBrush="White"
                                     BorderBrush="#55FFFFFF"
                                     BorderThickness="1"
                                     Padding="2,1"
                                     KeyDown="TitleBox_KeyDown"
                                     LostFocus="TitleBox_LostFocus"/>

                            <!-- TAB BUTTONS (when grouped) -->
                            <StackPanel x:Name="TabBar"
                                        Orientation="Horizontal"
                                        Visibility="Collapsed"
                                        VerticalAlignment="Center"
                                        Margin="2,0"
                                        Background="Transparent">
                                <!-- Tabs will be added dynamically -->
                            </StackPanel>
                        </Grid>

                        <!-- Close / Remove button -->
                        <Button Grid.Column="2"
                                Style="{StaticResource HeaderBtn}"
                                Click="CloseBtn_Click"
                                Margin="0,0,3,0"
                                ToolTip="Remove grid">
                            <TextBlock Text="✕" FontSize="10"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- ═══ CONTENT AREA ═══ -->
                <Grid x:Name="ContentArea" Grid.Row="1">

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <WrapPanel x:Name="IconPanel"
                                   Orientation="Horizontal"
                                   Margin="6,4"
                                   AllowDrop="True"
                                   Drop="IconPanel_Drop"
                                   DragOver="IconPanel_DragOver"/>
                    </ScrollViewer>

                    <!-- Empty state hint -->
                    <TextBlock x:Name="EmptyHint"
                               Text="Drop files here"
                               Foreground="#44FFFFFF"
                               FontSize="11"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False"/>

                    <!-- Right resize edge -->
                    <Thumb Width="5"
                           HorizontalAlignment="Right"
                           Background="Transparent"
                           Cursor="SizeWE"
                           DragDelta="RightThumb_DragDelta">
                        <Thumb.Template>
                            <ControlTemplate TargetType="Thumb">
                                <Border Background="Transparent"/>
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>
                </Grid>

                <!-- ═══ DELETE CONFIRMATION OVERLAY ═══ -->
                <Grid x:Name="DeleteConfirmOverlay"
                      Grid.Row="0" Grid.RowSpan="3"
                      Visibility="Collapsed"
                      Background="#EE0F1020">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="8">
                        <TextBlock Text="Grid entfernen?"
                                   Foreground="White"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="Ja"
                                    Width="56" Height="26"
                                    Margin="0,0,8,0"
                                    Foreground="White"
                                    Background="#CC993333"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="DeleteConfirmYes_Click"/>
                            <Button Content="Nein"
                                    Width="56" Height="26"
                                    Foreground="White"
                                    Background="#CC444466"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="DeleteConfirmNo_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- ═══ RESIZE STRIP ═══ -->
                <Grid x:Name="ResizeStrip" Grid.Row="2">
                    <!-- Bottom edge -->
                    <Thumb Background="Transparent"
                           Cursor="SizeNS"
                           DragDelta="BottomThumb_DragDelta">
                        <Thumb.Template>
                            <ControlTemplate TargetType="Thumb">
                                <Border Background="Transparent"/>
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>

                    <!-- Corner grip -->
                    <Thumb Width="16"
                           Height="8"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Bottom"
                           Cursor="SizeNWSE"
                           DragDelta="CornerThumb_DragDelta">
                        <Thumb.Template>
                            <ControlTemplate TargetType="Thumb">
                                <Canvas Width="16" Height="8">
                                    <Path Data="M 0,8 L 16,0 L 16,8 Z" Fill="#55FFFFFF"/>
                                </Canvas>
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>
                </Grid>

            </Grid>
        </Border>
    </Border>
</Window>
