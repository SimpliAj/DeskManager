<Window x:Class="DeskManager.Windows.PromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#FF1A1A2E"
        Foreground="White"
        SizeToContent="Height"
        Width="320"
        Title="DeskManager">

    <StackPanel Margin="16">
        <TextBlock x:Name="LabelText"
                   Foreground="#CCE0E0E0"
                   FontSize="12"
                   Margin="0,0,0,8"/>

        <TextBox x:Name="InputBox"
                 Background="#22FFFFFF"
                 Foreground="White"
                 CaretBrush="White"
                 BorderBrush="#44FFFFFF"
                 BorderThickness="1"
                 Padding="6,4"
                 FontSize="13"
                 KeyDown="InputBox_KeyDown"/>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Abbrechen"
                    Click="Cancel_Click"
                    Background="#33FFFFFF"
                    Foreground="White"
                    BorderThickness="0"
                    Padding="10,5"
                    Margin="0,0,8,0"/>
            <Button Content="OK"
                    Click="OK_Click"
                    Background="#AA0F3460"
                    Foreground="White"
                    BorderThickness="0"
                    Padding="10,5"/>
        </StackPanel>
    </StackPanel>
</Window>
